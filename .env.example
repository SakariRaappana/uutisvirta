# LLM provider: "claude" tai "openai"
LLM_PROVIDER=claude

# Anthropic — vaaditaan jos LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5

# OpenAI — vaaditaan jos LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# NewsAPI — vaaditaan avainsanahauille
NEWSAPI_KEY=...

# Output-hakemisto (oletus: ./output)
OUTPUT_DIR=
