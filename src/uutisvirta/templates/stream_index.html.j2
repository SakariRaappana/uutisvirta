{% extends "base.html.j2" %}
{% block title %}{{ stream.name }} — Uutisvirta{% endblock %}
{% block content %}
<h1>{{ stream.name }}</h1>
<p class="meta"><span>{{ digests | length }} julkaisua</span></p>

{% if digests %}
<ul class="archive-list">
  {% for d in digests %}
  <li>
    <span class="date">{{ d.date }}</span>
    <a href="{{ d.date }}.html">{{ d.title or d.date }}</a>
  </li>
  {% endfor %}
</ul>
{% else %}
<p>Ei vielä digestejä. Aja <code>uutisvirta</code> ensimmäisen kerran luodaksesi sisältöä.</p>
{% endif %}
{% endblock %}
